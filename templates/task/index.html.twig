{% extends 'base.html.twig' %}

{% block body %}
    <h1 class="mb-4">Liste des tâches</h1>

    {# Boutons pour les filtres #}
    <div class="mb-4">
        <a href="{{ path('app_task') }}" class="btn btn-primary">Toutes</a>
        <a href="{{ path('app_task_todo') }}" class="btn btn-warning">À faire</a>
        <a href="{{ path('app_task_done') }}" class="btn btn-success">Terminées</a>
    </div>

    {# Style bootstrap #}
    <ul class="list-group mb-4">
        {% for task in tasks %}
            <li class="list-group-item d-flex justify-content-between align-items-center">
                
                <div>
                    <span class="fs-5 me-2">
                        {% if task.isDone %} ✅ {% else %} ⬜ {% endif %}
                    </span>
                    
                    <strong>{{ task.title }}</strong> 
                    <span class="text-muted ms-2"> - {{ task.description }}</span>
                </div>
                <a href="{{ path('app_task_edit', {'id': task.id}) }}" class="btn btn-sm btn-outline-secondary">Modifier</a>
                
            </li>
        {% else %}
            <li class="list-group-item text-muted">Aucune tâche trouvée.</li>
        {% endfor %}
    </ul>

    {# Bouton pour ajouter une tache #}
    <a href="{{ path('app_task_create') }}" class="btn btn-success">+ Ajouter une tâche</a>
    
{% endblock %}